{
  "name": "gegato-abecia",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node scripts/env.js && ng serve",
    "build": "node scripts/env.js && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "tauri": "tauri",
    "all:web": "ng serve",
    "all:desktop": "wait-on http://localhost:4200 && npm run tauri dev",
    "all": "concurrently \"npm run all:web\" \"npm run all:desktop\""
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@primeuix/themes": "^2.0.2",
    "@tauri-apps/api": "^2.10.0",
    "dotenv": "^17.3.1",
    "firebase": "^9.22.1",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/fire": "^0.0.0",
    "@tauri-apps/cli": "^2.10.0",
    "@types/node": "^25.4.0",
    "concurrently": "^9.2.1",
    "jsdom": "^27.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.4"
  }
}
